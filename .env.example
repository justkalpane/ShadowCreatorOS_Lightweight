# Shadow Empire / Creator OS — Phase 1 local n8n example env
N8N_USER_FOLDER=C:\ShadowEmpire\n8n_user
N8N_DEFAULT_BINARY_DATA_MODE=filesystem
N8N_STORAGE_PATH=C:\ShadowEmpire\n8n_user\binaryData
N8N_HOST=127.0.0.1
N8N_PORT=5678

# Local folders
SHADOW_ROOT=C:\ShadowEmpire
SHADOW_REPO=C:\ShadowEmpire\Shadow-Creator-OS-Phase_01
SHADOW_DOSSIER_DIR=C:\ShadowEmpire\runtime\dossiers
SHADOW_PACKET_DIR=C:\ShadowEmpire\runtime\packets

# Local reasoning
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b

# Deferred providers (leave blank in Phase 1)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
