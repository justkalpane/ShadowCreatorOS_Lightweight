{
  "name": "shadow-creator-os-phase-1",
  "version": "1.0.0",
  "description": "Shadow Creator OS Phase-1: n8n-based agentic orchestration for automated AI YouTube content creation",
  "main": "index.js",
  "scripts": {
    "server": "node server.js",
    "operator:start": "node operator/server.js",
    "operator:health": "node operator/cli/health.cjs",
    "operator:ollama": "node operator/ollama_tool_runner.js",
    "operator:mcp": "node operator/mcp/shadow_operator_mcp_server.js",
    "operator:test": "node operator/tests/operator_acceptance_test.cjs",
    "operator:start:windows": "powershell -ExecutionPolicy Bypass -File scripts/windows/start_shadow_operator_api.ps1",
    "stack:start:windows": "powershell -ExecutionPolicy Bypass -File scripts/windows/start_shadow_stack.ps1",
    "dev": "node server.js",
    "start": "node server.js",
    "validate:all": "node validators/run_all_validators.cjs",
    "validate:workflows": "node validators/cli/validate_workflows.cjs",
    "validate:schemas": "node validators/cli/validate_schemas.cjs",
    "validate:registries": "node validators/cli/validate_registries.cjs",
    "validate:models": "node validators/model_validator.cjs",
    "validate:modes": "node validators/mode_validator.cjs",
    "validate:dossiers": "node validators/cli/validate_dossiers.cjs",
    "test:e2e": "jest --runInBand --verbose",
    "test:e2e:fast": "jest --runInBand --verbose --testNamePattern=fast",
    "test:e2e:replay": "jest --runInBand --verbose --testNamePattern=replay",
    "health:check": "node scripts/cli/health_check.cjs",
    "db:verify": "node scripts/cli/db_verify.cjs",
    "dossier:list": "node scripts/cli/dossier_list.cjs",
    "dossier:inspect": "node scripts/cli/dossier_inspect.cjs",
    "dossier:archive": "node scripts/cli/dossier_archive.cjs",
    "dossier:delete": "node scripts/cli/dossier_delete.cjs",
    "packet:list": "node scripts/cli/packet_list.cjs",
    "packet:inspect": "node scripts/cli/packet_inspect.cjs",
    "packet:lineage": "node scripts/cli/packet_lineage.cjs",
    "errors:list": "node scripts/cli/errors_list.cjs",
    "errors:clear": "node scripts/cli/errors_clear.cjs",
    "cost:report": "node scripts/cli/cost_report.cjs",
    "metrics:daily": "node scripts/cli/metrics_daily.cjs",
    "metrics:weekly": "node scripts/cli/metrics_weekly.cjs",
    "logs:view": "node scripts/cli/logs_view.cjs",
    "logs:clean": "node scripts/cli/logs_clean.cjs",
    "n8n:start": "n8n start",
    "n8n:start:bg": "n8n start --tunnel &",
    "n8n:stop": "node scripts/cli/n8n_stop.cjs",
    "n8n:status": "node scripts/cli/n8n_status.cjs",
    "webui:setup": "powershell -ExecutionPolicy Bypass -File scripts/windows/start_open_webui.ps1",
    "webui:setup:docker": "powershell -ExecutionPolicy Bypass -File scripts/windows/start_open_webui.ps1",
    "deploy:live-sync-enforcer": "node scripts/cli/deploy_live_sync_enforcer.cjs",
    "deploy:reconcile": "node scripts/cli/workflow_deploy_reconcile.cjs",
    "deploy:manifest-contract": "node scripts/cli/deploy_manifest_contract.cjs",
    "deploy:live-isolation": "node scripts/cli/deploy_live_isolation_contract.cjs",
    "deploy:state-contract": "node scripts/cli/deploy_state_contract.cjs",
    "deploy:error-route-contract": "node scripts/cli/deploy_error_route_contract.cjs",
    "deploy:chain-contract": "node scripts/cli/deploy_chain_contract.cjs",
    "deploy:ingress-contract": "node scripts/cli/deploy_ingress_contract.cjs",
    "deploy:credential-lock": "node scripts/cli/deploy_credential_provider_lock.cjs",
    "deploy:preflight": "node scripts/cli/deploy_preflight.cjs",
    "deploy:gate": "npm run deploy:live-sync-enforcer && npm run deploy:reconcile && npm run deploy:manifest-contract && npm run deploy:live-isolation && npm run deploy:state-contract && npm run deploy:error-route-contract && npm run deploy:chain-contract && npm run deploy:ingress-contract && npm run deploy:credential-lock && npm run deploy:preflight",
    "deploy:report": "node scripts/cli/deploy_gate_report.cjs",
    "deploy:gate:full": "npm run deploy:gate && npm run deploy:report",
    "deploy:release-manifest": "node scripts/cli/deploy_release_manifest.cjs",
    "deploy:rc-lock": "node scripts/cli/deploy_release_candidate_lock.cjs",
    "deploy:rc": "npm run deploy:gate:full && npm run deploy:rc-lock",
    "deploy:release": "npm run deploy:gate:full && npm run deploy:release-manifest",
    "deploy:regression-sweep": "node scripts/cli/deploy_regression_sweep.cjs",
    "deploy:persistence-contract": "node scripts/cli/deploy_persistence_contract.cjs",
    "deploy:persistence-cutover": "npm run deploy:regression-sweep && npm run deploy:persistence-contract",
    "deploy:approval-replay-contract": "npm run deploy:live-sync-enforcer && node scripts/cli/deploy_approval_replay_contract.cjs",
    "deploy:approval-replay-gate": "npm run deploy:approval-replay-contract",
    "deploy:phase8-proof": "node scripts/cli/deploy_phase8_wiring_proof.cjs",
    "deploy:promotion-gate": "node scripts/cli/deploy_release_promotion_gate.cjs",
    "deploy:production-candidate-manifest": "node scripts/cli/deploy_production_candidate_manifest.cjs",
    "deploy:signoff-gate": "npm run deploy:promotion-gate && npm run deploy:production-candidate-manifest && npm run deploy:preflight",
    "deploy:phase10-go-live-cutover": "node scripts/cli/deploy_phase10_go_live_cutover.cjs"
  },
  "keywords": [
    "n8n",
    "workflow-orchestration",
    "ai-content-creation",
    "automation",
    "youtube",
    "agentic-system",
    "dossier-state-management",
    "governance",
    "director-skill-model"
  ],
  "author": "Shadow Creator OS Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^3.0.1",
    "axios": "^1.15.2",
    "cors": "^2.8.6",
    "dotenv": "^16.3.0",
    "express": "^4.22.1",
    "pg": "^8.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "sqlite3": "^5.1.6",
    "winston": "^3.10.0",
    "yaml": "^2.3.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "node-mocks-http": "^1.13.0",
    "vite": "^8.0.10"
  }
}
