  "core_screens": {
    "dashboard": {
      "screen_id": "dashboard_main",
      "title": "System Dashboard",
      "description": "Primary control center: dossier overview, route selection, mode switching, workflow status",
      "url_route": "/dashboard",
      "role_access": ["creator", "builder", "operator", "founder"],
      "key_components": [
        "dossier_list_panel",
        "recent_runs_timeline",
        "mode_selector_widget",
        "model_selector_widget",
        "system_health_card",
        "quick_actions_bar"
      ],
      "data_sources": ["se_dossier_index", "se_route_runs", "model_registry", "mode_registry"],
      "refresh_interval_ms": 5000,
      "responsive_breakpoints": ["mobile_320px", "tablet_768px", "desktop_1920px"],
      "key_actions": ["create_new_dossier", "view_dossier_details", "switch_mode", "switch_model", "start_workflow"]
    },

    "mission_control": {
      "screen_id": "mission_control_orchestrator",
      "title": "Mission Control",
