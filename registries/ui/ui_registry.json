      "role_access": ["builder", "founder"],
      "key_components": [
        "workflow_orchestration_canvas",
        "packet_flow_visualizer",
        "stage_status_matrix",
        "execution_timeline",
        "interrupt_control_panel"
      ],
      "data_sources": ["se_route_runs", "se_packet_index", "dossier.runtime"],
      "refresh_interval_ms": 1000,
      "visualization_type": "dag_flowchart_with_realtime_status",
      "key_actions": ["pause_workflow", "resume_workflow", "skip_stage", "trigger_emergency_stop"]
    },

