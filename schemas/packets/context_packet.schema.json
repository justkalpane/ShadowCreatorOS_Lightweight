{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shadow-empire.local/schemas/packets/context_packet.schema.json",
  "title": "ContextEngineeringPacket",
  "type": "object",
  "required": [
    "packet_id",
    "dossier_id",
    "context_type",
    "intent",
    "audience",
    "evidence_standard",
    "constraints",
    "source_packet_refs",
    "target_module",
    "context_version",
    "payload",
    "status"
  ],
  "properties": {
    "packet_id": {
      "type": "string"
    },
    "dossier_id": {
      "type": "string"
    },
    "context_type": {
      "type": "string",
      "enum": [
        "topic",
        "research",
        "script",
        "approval",
        "runtime",
        "resource_prep"
      ]
    },
    "intent": {
      "type": "string"
    },
    "audience": {
      "type": "string"
    },
    "tone": {
      "type": "string"
    },
    "evidence_standard": {
      "type": "string",
      "enum": [
        "light",
        "standard",
        "strict"
      ]
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_packet_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "target_module": {
      "type": "string",
      "enum": [
        "topic_intelligence",
        "script_intelligence",
        "context_engineering",
        "approval_pack",
        "runtime_governance"
      ]
    },
    "context_version": {
      "type": "integer",
      "minimum": 1
    },
    "payload": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": true
    },
    "status": {
      "type": "string",
      "enum": [
        "CREATED",
        "SUCCESS",
        "FAILURE",
        "PENDING",
        "RETRY",
        "RECOVERED",
        "ESCALATED",
        "EMITTED"
      ]
    }
  },
  "additionalProperties": true
}