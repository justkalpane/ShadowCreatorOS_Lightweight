{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "downstream_resource_prep_plan",
  "type": "object",
  "required": [
    "packet_family",
    "asset_classes",
    "sequencing",
    "replay_reference"
  ],
  "properties": {
    "packet_family": {
      "type": "string",
      "const": "downstream_resource_prep_plan"
    },
    "asset_classes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "owner",
          "priority"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          },
          "priority": {
            "type": "string"
          }
        }
      }
    },
    "sequencing": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "replay_reference": {
      "type": "object",
      "required": [
        "workflow",
        "timestamp"
      ],
      "properties": {
        "workflow": {
          "type": "string"
        },
        "dossier_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "timestamp": {
          "type": "string"
        }
      }
    }
  },
  "additionalProperties": true
}