{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "M-107 packet schema",
  "type": "object",
  "required": [
    "instance_id",
    "artifact_family",
    "schema_version",
    "producer_workflow",
    "dossier_ref",
    "created_at",
    "status",
    "payload"
  ],
  "properties": {
    "instance_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]{1,128}$",
      "minLength": 1
    },
    "artifact_family": {
      "type": "string",
      "const": "m107_packet"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+(.[0-9]+)*$"
    },
    "producer_workflow": {
      "type": "string",
      "pattern": "^(WF|CWF)-[A-Z0-9-]+$"
    },
    "dossier_ref": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "CREATED",
        "SUCCESS",
        "FAILURE",
        "PENDING",
        "RETRY",
        "RECOVERED",
        "ESCALATED",
        "EMITTED"
      ]
    },
    "payload": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}