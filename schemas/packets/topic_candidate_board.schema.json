{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shadow-empire.local/schemas/packets/topic_candidate_board.schema.json",
  "title": "TopicCandidateBoard",
  "type": "object",
  "required": [
    "packet_id",
    "dossier_id",
    "candidates",
    "candidate_count",
    "created_at"
  ],
  "properties": {
    "packet_id": {
      "type": "string"
    },
    "dossier_id": {
      "type": "string"
    },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "candidate_id",
          "title",
          "thesis",
          "signal_sources",
          "priority_band",
          "status"
        ],
        "properties": {
          "candidate_id": {
            "type": "string"
          },
          "title": {
            "type": "string",
            "minLength": 3
          },
          "thesis": {
            "type": "string",
            "minLength": 5
          },
          "hook_angle": {
            "type": "string"
          },
          "signal_sources": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "priority_band": {
            "type": "string",
            "enum": [
              "P0",
              "P1",
              "P2"
            ]
          },
          "estimated_strength": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "risk_flags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "discovered",
              "qualified",
              "rejected",
              "promoted"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "candidate_count": {
      "type": "integer",
      "minimum": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}