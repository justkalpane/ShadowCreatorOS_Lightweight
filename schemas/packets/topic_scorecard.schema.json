{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shadow-empire.local/schemas/packets/topic_scorecard.schema.json",
  "title": "TopicScorecard",
  "type": "object",
  "required": [
    "packet_id",
    "dossier_id",
    "ranked_topics",
    "selected_topic_id",
    "created_at"
  ],
  "properties": {
    "packet_id": {
      "type": "string"
    },
    "dossier_id": {
      "type": "string"
    },
    "ranked_topics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "candidate_id",
          "total_score"
        ],
        "properties": {
          "candidate_id": {
            "type": "string"
          },
          "total_score": {
            "type": "number"
          }
        }
      }
    },
    "selected_topic_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}