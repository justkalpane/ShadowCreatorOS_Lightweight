{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Visual Asset Specification Packet",
  "description": "Schema for visual asset specifications from CWF-420-visual-asset-planner",
  "type": "object",
  "required": [
    "instance_id",
    "artifact_family",
    "schema_version",
    "producer_workflow",
    "dossier_ref",
    "created_at",
    "status",
    "payload"
  ],
  "properties": {
    "instance_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]{1,128}$",
      "minLength": 1
    },
    "artifact_family": {
      "type": "string",
      "enum": [
        "visual_asset_spec_packet"
      ],
      "description": "Packet type identifier"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+(.[0-9]+)*$"
    },
    "producer_workflow": {
      "type": "string",
      "pattern": "^(WF|CWF)-[A-Z0-9-]+$"
    },
    "dossier_ref": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "CREATED",
        "SUCCESS",
        "FAILURE",
        "PENDING",
        "RETRY",
        "RECOVERED",
        "ESCALATED",
        "EMITTED"
      ]
    },
    "payload": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": true
    }
  },
  "definitions": {
    "visual_element": {
      "type": "object",
      "required": [
        "element_id",
        "type",
        "description",
        "estimated_duration"
      ],
      "properties": {
        "element_id": {
          "type": "string",
          "pattern": "^[a-z_]+_[0-9]+$"
        },
        "type": {
          "type": "string",
          "enum": [
            "b-roll",
            "graphic",
            "text",
            "transition"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 10,
          "maxLength": 500
        },
        "b_roll_suggestions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "estimated_duration": {
          "type": "string",
          "pattern": "^[0-9]+(\\.[0-9]+)?$",
          "description": "Duration in seconds"
        },
        "timing_marker": {
          "type": "string",
          "pattern": "^[0-9]{2}:[0-5][0-9]-[0-9]{2}:[0-5][0-9]$",
          "description": "Timing in MM:SS-MM:SS format"
        }
      }
    }
  },
  "additionalProperties": true
}