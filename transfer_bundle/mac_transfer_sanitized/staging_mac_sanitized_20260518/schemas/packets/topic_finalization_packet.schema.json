{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shadow-empire.local/schemas/packets/topic_finalization_packet.schema.json",
  "title": "TopicFinalizationPacket",
  "type": "object",
  "required": [
    "packet_id",
    "dossier_id",
    "selected_topic",
    "approval_state",
    "created_at"
  ],
  "properties": {
    "packet_id": {
      "type": "string"
    },
    "dossier_id": {
      "type": "string"
    },
    "selected_topic": {
      "type": "string"
    },
    "approval_state": {
      "type": "string",
      "enum": [
        "APPROVED",
        "REVISE",
        "REJECT"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}